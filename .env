# Copy to .env in this directory and adjust as needed.
# These only configure the Docker containers themselves (ports, DB creds,
# host UID/GID). Laravel's own settings still come from ../html/.env —
# these values override matching keys (DB_HOST, REDIS_HOST, etc.) so the
# app talks to the containers instead of localhost.

# Host UID/GID the app container's www-data user should match,
# so files created by the container stay owned by you on the host.
# Run `id -u` / `id -g` to find your own values.
WWWUSER=1000
WWWGROUP=1000

# Port on the HOST machine that nginx will be published to.
# Point climbing.loc and its subdomains at 127.0.0.1 in /etc/hosts.
APP_PORT=80

# MySQL
DB_DATABASE=climbing_loc_db
DB_USERNAME=climbing
DB_PASSWORD=climbing
DB_ROOT_PASSWORD=root
DB_FORWARD_PORT=3306

# Redis
REDIS_FORWARD_PORT=6379

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database
